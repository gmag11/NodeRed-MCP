# Node-RED instance URL (required)
# When running in Docker Compose, use: http://nodered:1880
# When running locally, use: http://localhost:1880
NODERED_URL=http://nodered:1880

# Authentication: standard credentials (optional)
# Used when Node-RED has adminAuth with type "credentials"
NODERED_USERNAME=
NODERED_PASSWORD=

# Authentication: static API key (optional)
# Used for OIDC/strategy-based auth. When set, takes priority over username/password.
# Requires a matching `tokens` function in Node-RED's settings.js
NODERED_API_KEY=

# HTTP transport port (optional, default: 3000)
MCP_HTTP_PORT=3000

# ── MCP Server Authentication ────────────────────────────────────
#
# API Key (optional)
# When set, all /mcp requests must include the header:
#   Authorization: Bearer <your-key>
# To generate a secure key:
#   openssl rand -hex 32
MCP_API_KEY=

# OAuth 2.0 (optional, requires MCP_OAUTH_ENABLED=true)
# Enable to expose an OAuth 2.0 authorization server with dynamic
# client registration, PKCE flow, and token management.
# MCP_OAUTH_ENABLED=false
# MCP_OAUTH_ISSUER_URL=https://your-server.example.com

# OAuth store paths (optional, defaults shown)
# MCP_OAUTH_CLIENTS_FILE=./oauth-clients.json
# MCP_OAUTH_TOKENS_FILE=./oauth-tokens.json
